{
  "name": "educator-js-codespace-template",
  "version": "1.0.0",
  "description": "Educator JS Codespace Template",
  "homepage": "https://e-a.codes",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "vite build",
    "build-gh": "vite build --base=/ && powershell -Command \"Copy-Item -Path dist/index.html -Destination dist/404.html\" && powershell -Command \"Set-Content -Path dist/CNAME -Value 'e-a.codes'\"",
    "predeploy": "npm run build-gh",
    "deploy": "gh-pages -d dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/juniorGitH/Emmanuel_Amela.git"
  },
  "author": "Microsoft",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/juniorGitH/Emmanuel_Amela/issues"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.5.1",
    "@fortawesome/free-solid-svg-icons": "^6.5.1",
    "@fortawesome/react-fontawesome": "^0.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.14",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.34.1",
    "gh-pages": "^6.3.0",
    "jsdom": "^24.1.3",
    "postcss": "^8.4.43",
    "prettier": "^3.3.3",
    "serve": "^14.2.4",
    "tailwindcss": "^3.4.10",
    "vite": "^5.4.2",
    "vitest": "^2.1.8"
  },
  "overrides": {
    "ajv": "8.17.1",
    "minimatch": "3.1.2",
    "glob": "7.2.3",
    "inflight": "1.0.6",
    "rimraf": "3.0.2"
  }
}