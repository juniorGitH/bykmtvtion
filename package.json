{
  "name": "Emmanuel_Amela",
  "version": "1.0.0",
  "description": "BYKMTVTION is a fitness coaching business that offers personalized training programs and nutrition plans to help clients achieve their fitness goals. With a team of experienced coaches and a focus on holistic wellness, BYKMTVTION provides support and guidance to individuals looking to improve their physical health and overall well-being.",
  "homepage": "https://bykmtvtion.com",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "vite build",
    "build-gh": "vite build --base=/ && powershell -Command \"Copy-Item -Path dist/index.html -Destination dist/404.html\" && powershell -Command \"Set-Content -Path dist/CNAME -Value 'bykmtvtion.com'\"",
    "predeploy": "npm run build-gh",
    "deploy": "gh-pages -d dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/juniorGitH/bykmtvtion.git"
  },
  "author": "Microsoft",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/juniorGitH/bykmtvtion/issues"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^6.5.1",
    "@fortawesome/free-solid-svg-icons": "^6.5.1",
    "@fortawesome/react-fontawesome": "^0.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.14",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.34.1",
    "gh-pages": "^6.1.1",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.24",
    "prettier": "^3.2.5",
    "serve": "^14.2.1",
    "tailwindcss": "^3.3.2",
    "vite": "^5.2.0",
    "vitest": "^2.1.8"
  }
}
